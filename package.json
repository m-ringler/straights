{
  "name": "straights",
  "private": true,
  "version": "0.8.6",
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/serviceworker": "^0.0.196",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.2",
    "cheerio": "^1.2.0",
    "jquery": "^4.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80
  },
  "scripts": {
    "format": "prettier --write \"webdev/**/*.js\" \"**/*.{ts,css,html,json}\"",
    "tsc": "tsc -p tsconfig.json",
    "tsc:watch": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:debug": "vitest --inspect-brk --no-coverage"
  }
}
